{
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "skills:sync": "node scripts/sync-skills.mjs write",
    "skills:check": "node scripts/sync-skills.mjs check",
    "codegen": "pnpm --recursive --parallel --filter \"./packages/**/*\" run codegen",
    "build": "tspc -b tsconfig.build.json && pnpm --recursive --filter \"./packages/**/*\" run build",
    "build:tsgo": "tsgo -b tsconfig.build.json && pnpm --recursive --filter \"./packages/**/*\" run build",
    "audit": "pnpm audit --prod && pnpm audit --dev",
    "test": "vitest && pnpm test:pack",
    "test:pack": "pnpm --recursive --filter \"./packages/**/*\" --if-present run test:pack",
    "test:browser": "pnpm --workspace-concurrency=1 --recursive --filter \"./packages/**/*\" --if-present run test:browser",
    "coverage": "vitest --coverage",
    "check": "pnpm build && pnpm --recursive --filter \"./packages/**/*\" run check",
    "check:tsgo": "pnpm --recursive --filter \"./packages/**/*\" --filter \"!@knpkv/agent-skills\" exec tsgo -b tsconfig.json",
    "lint": "pnpm lint:config && pnpm lint:eslint && pnpm lint:ast && pnpm lint:rly-colors && pnpm lint:rly-css-tokens",
    "lint:config": "node scripts/check-eslint-config.mjs",
    "lint:eslint": "eslint --no-error-on-unmatched-pattern \"**/{src,test,e2e,examples,dtslint}/**/*.{ts,tsx,mjs}\" \"**/scripts/**/*.{ts,tsx}\" \"packages/control-center/{vite,vitest,playwright}.config.ts\"",
    "lint:rly-colors": "pnpm --filter @knpkv/rly lint:colors",
    "lint:rly-css-tokens": "pnpm --filter @knpkv/control-center lint:rly-css-tokens",
    "lint:ast": "ast-grep test && ast-grep scan --globs '!**/generated/**'",
    "lint:fix": "pnpm lint:eslint --fix && pnpm lint:ast --update-all",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm build && changeset publish",
    "prepare": "ts-patch install -s && effect-tsgo patch && husky"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.44.1",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@effect/build-utils": "^0.8.9",
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "^0.86.6",
    "@effect/platform-node": "4.0.0-beta.98",
    "@effect/tsgo": "^0.19.0",
    "@effect/vitest": "4.0.0-beta.98",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@typescript/native": "npm:typescript@7.0.2",
    "@typescript/native-preview": "7.0.0-dev.20260705.1",
    "@vitest/coverage-v8": "^4.1.10",
    "effect": "4.0.0-beta.98",
    "eslint": "^10.7.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-local-rules": "^3.0.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sort-destructure-keys": "^3.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "ts-patch": "^4.0.1",
    "tslib": "^2.8.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "catalog:"
  }
}
