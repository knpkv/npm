{
  "name": "@knpkv/ai-codex",
  "version": "0.0.0",
  "description": "Effect AI language model backed by the local Codex CLI",
  "license": "MIT",
  "author": "knpkv",
  "repository": {
    "type": "git",
    "url": "https://github.com/knpkv/npm.git",
    "directory": "packages/ai-codex"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b --force && node scripts/validate-dist.mjs",
    "check": "tsc --noEmit",
    "clean": "rimraf dist *.tsbuildinfo",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "vitest run",
    "test:smoke:real": "AI_CODEX_REAL_SMOKE=1 vitest run --config vitest.smoke.config.ts"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.97"
  },
  "devDependencies": {
    "@effect/platform-node": "4.0.0-beta.97",
    "@effect/vitest": "4.0.0-beta.97",
    "@types/node": "^26.1.1",
    "effect": "4.0.0-beta.97",
    "rimraf": "^6.1.3",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "effect",
    "effect-ai",
    "codex",
    "agent",
    "cli"
  ]
}
