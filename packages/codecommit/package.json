{
  "name": "@knpkv/codecommit",
  "version": "0.7.0",
  "description": "TUI for browsing AWS CodeCommit PRs",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/dts/index.d.ts",
  "bin": {
    "codecommit": "dist/src/bin.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "start": "bun src/bin.ts",
    "start:web": "bun src/bin.ts web",
    "prepack": "tsc -b",
    "build": "tsc -b",
    "check": "tsc -b tsconfig.json",
    "test": "vitest",
    "lint": "eslint \"{src,test}/**/*.{ts,tsx}\"",
    "docgen": "docgen"
  },
  "dependencies": {
    "@effect/atom-react": "4.0.0-beta.93",
    "@effect/platform-bun": "4.0.0-beta.93",
    "@effect/platform-node": "4.0.0-beta.93",
    "@knpkv/agent-skills": "workspace:^",
    "@knpkv/codecommit-core": "workspace:^",
    "@knpkv/codecommit-web": "workspace:^",
    "@opentui/core": "https://pkg.pr.new/anomalyco/opentui/@opentui/core@367a94087821b3b5feedd35bbb57df43b10a286e",
    "@opentui/react": "https://pkg.pr.new/anomalyco/opentui/@opentui/react@367a94087821b3b5feedd35bbb57df43b10a286e",
    "effect": "4.0.0-beta.93",
    "react": "^19.2.7",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.93",
    "@storybook/react": "^10.4.6",
    "@types/bun": "^1.3.14",
    "@types/node": "latest",
    "@types/react": "^19.2.17",
    "storybook": "^10.4.6",
    "vitest": "^4.1.9"
  }
}
