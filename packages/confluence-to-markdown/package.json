{
  "name": "@knpkv/confluence-to-markdown",
  "version": "1.1.0",
  "description": "Sync Confluence Cloud pages to local GitHub Flavored Markdown files",
  "license": "MIT",
  "author": "knpkv",
  "repository": {
    "type": "git",
    "url": "https://github.com/knpkv/npm.git",
    "directory": "packages/confluence-to-markdown"
  },
  "bugs": {
    "url": "https://github.com/knpkv/npm/issues"
  },
  "homepage": "https://github.com/knpkv/npm/tree/main/packages/confluence-to-markdown#readme",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "confluence": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./Brand": {
      "import": "./dist/Brand.js",
      "types": "./dist/Brand.d.ts"
    },
    "./Schemas": {
      "import": "./dist/Schemas.js",
      "types": "./dist/Schemas.d.ts"
    },
    "./ConfluenceError": {
      "import": "./dist/ConfluenceError.js",
      "types": "./dist/ConfluenceError.d.ts"
    },
    "./ConfluenceConfig": {
      "import": "./dist/ConfluenceConfig.js",
      "types": "./dist/ConfluenceConfig.d.ts"
    },
    "./ConfluenceAuth": {
      "import": "./dist/ConfluenceAuth.js",
      "types": "./dist/ConfluenceAuth.d.ts"
    },
    "./ConfluenceClient": {
      "import": "./dist/ConfluenceClient.js",
      "types": "./dist/ConfluenceClient.d.ts"
    },
    "./MarkdownConverter": {
      "import": "./dist/MarkdownConverter.js",
      "types": "./dist/MarkdownConverter.d.ts"
    },
    "./AdfSchemaValidator": {
      "import": "./dist/AdfSchemaValidator.js",
      "types": "./dist/AdfSchemaValidator.d.ts"
    },
    "./AdfWalker": {
      "import": "./dist/AdfWalker.js",
      "types": "./dist/AdfWalker.d.ts"
    },
    "./AtlaskitTransformers": {
      "import": "./dist/AtlaskitTransformers.js",
      "types": "./dist/AtlaskitTransformers.d.ts"
    },
    "./LocalFileSystem": {
      "import": "./dist/LocalFileSystem.js",
      "types": "./dist/LocalFileSystem.d.ts"
    },
    "./SyncEngine": {
      "import": "./dist/SyncEngine.js",
      "types": "./dist/SyncEngine.d.ts"
    },
    "./GitError": {
      "import": "./dist/GitError.js",
      "types": "./dist/GitError.d.ts"
    },
    "./GitService": {
      "import": "./dist/GitService.js",
      "types": "./dist/GitService.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist dist-test .tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "check": "tsc --noEmit",
    "link": "npm link"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.87"
  },
  "dependencies": {
    "@atlaskit/adf-schema": "^56.0.4",
    "@atlaskit/editor-json-transformer": "^9.0.1",
    "@atlaskit/editor-markdown-transformer": "^6.0.1",
    "@effect/platform-node": "4.0.0-beta.87",
    "@knpkv/agent-skills": "workspace:^",
    "@knpkv/atlassian-common": "workspace:*",
    "@knpkv/confluence-api-client": "workspace:^",
    "ajv": "^8.20.0",
    "ajv-draft-04": "^1.0.0",
    "js-yaml": "^4.2.0"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.87",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.0.0",
    "effect": "4.0.0-beta.87",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "effect",
    "effect-ts",
    "confluence",
    "markdown",
    "sync",
    "atlassian",
    "documentation",
    "cli",
    "git",
    "version-control"
  ]
}
