{
  "name": "@knpkv/codecommit-core",
  "version": "0.8.0",
  "description": "Core logic for CodeCommit PR browser",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./Domain.js": "./src/Domain.ts",
    "./CacheService.js": "./src/CacheService/index.ts",
    "./ConfigService.js": "./src/ConfigService/index.ts",
    "./ReadClient.js": "./src/ReadClient/index.ts",
    "./SandboxService.js": "./src/SandboxService/index.ts",
    "./*.js": "./src/*.ts"
  },
  "publishConfig": {
    "access": "public",
    "main": "dist/index.js",
    "types": "dist/dts/index.d.ts",
    "exports": {
      ".": "./dist/index.js",
      "./ConfigService.js": "./dist/ConfigService/index.js",
      "./ReadClient.js": "./dist/ReadClient/index.js",
      "./*.js": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "tsc",
    "build": "tsc",
    "check": "tsc -b tsconfig.json",
    "test": "vitest",
    "test:pack": "tsx scripts/test-packed-package.ts",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "docgen": "docgen"
  },
  "dependencies": {
    "@aws-sdk/credential-providers": "^3.1085.0",
    "@distilled.cloud/aws": "0.29.1",
    "@effect/sql-libsql": "4.0.0-beta.98",
    "@libsql/client": "^0.17.4",
    "effect": "4.0.0-beta.98"
  },
  "devDependencies": {
    "@effect/platform-node": "4.0.0-beta.98"
  }
}
