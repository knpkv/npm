{
  "name": "@knpkv/codecommit-core",
  "version": "0.7.1",
  "description": "Core logic for CodeCommit PR browser",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./Domain.js": "./src/Domain.ts",
    "./CacheService.js": "./src/CacheService/index.ts",
    "./SandboxService.js": "./src/SandboxService/index.ts",
    "./*.js": "./src/*.ts"
  },
  "publishConfig": {
    "access": "public",
    "main": "dist/index.js",
    "types": "dist/dts/index.d.ts",
    "exports": {
      ".": "./dist/index.js",
      "./*.js": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "tsc",
    "build": "tsc",
    "check": "tsc -b tsconfig.json",
    "test": "vitest",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "docgen": "docgen"
  },
  "dependencies": {
    "@aws-sdk/credential-providers": "^3.974.0",
    "@effect/platform": "workspace:*",
    "@effect/sql-libsql": "4.0.0-beta.85",
    "@libsql/client": "^0.14.0",
    "distilled-aws": "0.0.21",
    "effect": "latest"
  },
  "devDependencies": {}
}
