{
  "name": "@knpkv/codecommit-web",
  "version": "0.11.2",
  "description": "Web server and frontend for CodeCommit PR browser",
  "type": "module",
  "main": "src/index.ts",
  "publishConfig": {
    "access": "public",
    "main": "dist/index.js",
    "types": "dist/dts/index.d.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "bun run --watch src/main.ts & vite --clearScreen false",
    "prepack": "tsc -b && vite build",
    "build": "tsc -b && vite build",
    "check": "tsc -b tsconfig.json",
    "test": "vitest",
    "lint": "eslint \"{src,test}/**/*.{ts,tsx}\"",
    "docgen": "docgen"
  },
  "dependencies": {
    "@effect/atom-react": "4.0.0-beta.98",
    "@effect/platform-bun": "4.0.0-beta.98",
    "@effect/platform-node": "4.0.0-beta.98",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@formkit/auto-animate": "^0.10.0",
    "@knpkv/codecommit-core": "workspace:^",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "effect": "4.0.0-beta.98",
    "lucide-react": "^1.24.0",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router": "^8.2.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.98",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
