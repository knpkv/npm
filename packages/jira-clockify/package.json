{
  "name": "@knpkv/jira-clockify",
  "version": "1.0.2",
  "description": "TUI for Jira-Clockify time tracking, attachable to neovim",
  "license": "MIT",
  "author": "knpkv",
  "type": "module",
  "bin": {
    "jcf": "dist/src/bin.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "nvim",
    "skills"
  ],
  "scripts": {
    "start": "tsx src/bin.ts",
    "build": "tsc -b && chmod +x dist/src/bin.js",
    "check": "tsc -b tsconfig.json",
    "test": "vitest",
    "lint": "eslint \"{src,test}/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@effect/atom-react": "4.0.0-beta.93",
    "@effect/platform-node": "4.0.0-beta.93",
    "@knpkv/agent-skills": "workspace:^",
    "@knpkv/atlassian-common": "workspace:^",
    "@knpkv/clockify-api-client": "workspace:^",
    "@knpkv/jira-api-client": "workspace:^",
    "@knpkv/jira-cli": "workspace:^",
    "@opentui/core": "https://pkg.pr.new/anomalyco/opentui/@opentui/core@367a94087821b3b5feedd35bbb57df43b10a286e",
    "@opentui/react": "https://pkg.pr.new/anomalyco/opentui/@opentui/react@367a94087821b3b5feedd35bbb57df43b10a286e",
    "effect": "4.0.0-beta.93",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.93",
    "@types/node": "latest",
    "@types/react": "^19.2.17",
    "tsx": "^4.23.0",
    "vitest": "^4.1.9"
  }
}
