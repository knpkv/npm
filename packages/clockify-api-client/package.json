{
  "name": "@knpkv/clockify-api-client",
  "version": "1.0.0",
  "description": "Effect-based Clockify REST API client",
  "license": "MIT",
  "author": "knpkv",
  "repository": {
    "type": "git",
    "url": "https://github.com/knpkv/npm.git",
    "directory": "packages/clockify-api-client"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ClockifyApiClient": {
      "import": "./dist/ClockifyApiClient.js",
      "types": "./dist/ClockifyApiClient.d.ts"
    },
    "./ClockifyApiConfig": {
      "import": "./dist/ClockifyApiConfig.js",
      "types": "./dist/ClockifyApiConfig.d.ts"
    },
    "./generated": {
      "import": "./dist/generated/ClockifyApi.js",
      "types": "./dist/generated/ClockifyApi.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit && tsc -p scripts/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "regenerate": "tsx scripts/regenerate.ts",
    "regenerate:check": "tsx scripts/regenerate.ts --check"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.98"
  },
  "devDependencies": {
    "@effect/openapi-generator": "4.0.0-beta.98",
    "@effect/platform-node": "4.0.0-beta.98",
    "@effect/vitest": "4.0.0-beta.98",
    "@types/node": "latest",
    "effect": "4.0.0-beta.98",
    "prettier": "^3.9.5",
    "tsx": "^4.23.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "effect",
    "effect-ts",
    "clockify",
    "time-tracking",
    "api-client",
    "openapi"
  ]
}
