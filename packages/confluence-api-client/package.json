{
  "name": "@knpkv/confluence-api-client",
  "version": "0.4.0",
  "description": "Effect-based Confluence Cloud REST API client (v1 + v2)",
  "license": "MIT",
  "author": "knpkv",
  "repository": {
    "type": "git",
    "url": "https://github.com/knpkv/npm.git",
    "directory": "packages/confluence-api-client"
  },
  "bugs": {
    "url": "https://github.com/knpkv/npm/issues"
  },
  "homepage": "https://github.com/knpkv/npm/tree/main/packages/confluence-api-client#readme",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ConfluenceApiClient": {
      "import": "./dist/ConfluenceApiClient.js",
      "types": "./dist/ConfluenceApiClient.d.ts"
    },
    "./ConfluenceApiConfig": {
      "import": "./dist/ConfluenceApiConfig.js",
      "types": "./dist/ConfluenceApiConfig.d.ts"
    },
    "./generated/v1": {
      "import": "./dist/generated/ConfluenceV1Api.js",
      "types": "./dist/generated/ConfluenceV1Api.d.ts"
    },
    "./generated/v2": {
      "import": "./dist/generated/ConfluenceV2Api.js",
      "types": "./dist/generated/ConfluenceV2Api.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist dist-test .tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "check": "tsc --noEmit && tsc -p scripts/tsconfig.json",
    "regenerate": "tsx scripts/regenerate.ts",
    "regenerate:check": "tsx scripts/regenerate.ts --check"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.97"
  },
  "devDependencies": {
    "@effect/openapi-generator": "4.0.0-beta.97",
    "@effect/platform-node": "4.0.0-beta.97",
    "@effect/vitest": "4.0.0-beta.97",
    "@types/node": "latest",
    "effect": "4.0.0-beta.97",
    "prettier": "^3.9.5",
    "tsx": "^4.23.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "effect",
    "effect-ts",
    "confluence",
    "atlassian",
    "api-client",
    "openapi"
  ]
}
