{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.jsonc",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022"],
    "noEmit": true,
    "rootDir": ".",
    "tsBuildInfoFile": "node_modules/.cache/tsconfig.node.tsbuildinfo",
    "types": ["node", "vitest/globals"]
  },
  "include": ["e2e", "playwright.config.ts", "scripts", "src/domain", "test", "vite.config.ts", "vitest.config.ts"],
  "exclude": ["dist", "node_modules"]
}
