{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.jsonc",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022"],
    "noEmit": true,
    "rootDir": ".",
    "tsBuildInfoFile": "node_modules/.cache/tsconfig.node.tsbuildinfo",
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "e2e",
    "playwright.config.ts",
    "scripts",
    "src/api",
    "src/domain",
    "src/server",
    "src/server/persistence/schema.json",
    "test",
    "vite.config.ts",
    "vitest.config.ts"
  ],
  "exclude": ["dist", "node_modules", "test/client"],
  "references": [{ "path": "../control-center-sql/tsconfig.build.json" }]
}
