{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.jsonc",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "noEmit": true,
    "rootDir": "src",
    "tsBuildInfoFile": "node_modules/.cache/tsconfig.client.tsbuildinfo",
    "types": ["vite/client"]
  },
  "include": ["src/api", "src/client", "src/domain"],
  "exclude": ["dist", "node_modules", "src/server"]
}
