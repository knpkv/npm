{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.jsonc",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "noEmit": true,
    "rootDir": ".",
    "tsBuildInfoFile": "node_modules/.cache/tsconfig.client-test.tsbuildinfo",
    "types": ["vite/client", "vitest/globals"]
  },
  "include": ["src/api", "src/client", "src/domain", "test/client", "test/fixtures/releaseWorkset.ts"],
  "exclude": ["dist", "node_modules"]
}
