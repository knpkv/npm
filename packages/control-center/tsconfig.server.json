{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.jsonc",
  "compilerOptions": {
    "emitDeclarationOnly": true,
    "lib": ["ES2022"],
    "outDir": "dist/server",
    "rootDir": "src",
    "stripInternal": true,
    "tsBuildInfoFile": "node_modules/.cache/tsconfig.server.tsbuildinfo",
    "types": ["node"]
  },
  "include": ["src/index.ts", "src/api", "src/domain", "src/server"],
  "exclude": ["dist", "node_modules", "src/client"],
  "references": [{ "path": "../ai-claude/tsconfig.build.json" }, { "path": "../ai-codex/tsconfig.build.json" }]
}
