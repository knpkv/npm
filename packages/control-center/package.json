{
  "name": "@knpkv/control-center",
  "version": "0.0.0",
  "description": "Human- and agent-oriented delivery control center",
  "license": "MIT",
  "author": "knpkv",
  "repository": {
    "type": "git",
    "url": "https://github.com/knpkv/npm.git",
    "directory": "packages/control-center"
  },
  "type": "module",
  "bin": {
    "control-center": "./dist/server/server/cli.js"
  },
  "main": "./dist/server/index.js",
  "types": "./dist/server/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./api": {
      "types": "./dist/server/api/index.d.ts",
      "import": "./dist/server/api/index.js"
    },
    "./domain": {
      "types": "./dist/server/domain/index.d.ts",
      "import": "./dist/server/domain/index.js"
    },
    "./server": {
      "types": "./dist/server/server/index.d.ts",
      "import": "./dist/server/server/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "benchmark": "pnpm benchmark:contracts && pnpm benchmark:runtime",
    "benchmark:contracts": "tsx scripts/runBenchmark.ts",
    "benchmark:runtime": "pnpm build && rimraf test-results/control-center/runtime-benchmark.json && CONTROL_CENTER_RUNTIME_BENCHMARK_OUTPUT=test-results/control-center/runtime-benchmark.json playwright test e2e/real-runtime.spec.ts --grep \"measures warmed\" --config playwright.config.ts && CONTROL_CENTER_RUNTIME_BENCHMARK_OUTPUT=test-results/control-center/runtime-benchmark.json tsx scripts/validateRuntimeBenchmarkReport.ts",
    "build": "pnpm validate:boundaries && rimraf dist && vite build --mode client && vite build --mode server && tsc -b tsconfig.server.json --force && pnpm validate:dist",
    "check": "pnpm validate:boundaries && pnpm lint:rly-css-tokens && tsc -b tsconfig.json",
    "clean": "rimraf dist *.tsbuildinfo node_modules/.cache",
    "dev": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "lint": "eslint \"{src,test,e2e,scripts}/**/*.{ts,tsx}\" vite.config.ts vitest.config.ts playwright.config.ts && pnpm lint:rly-css-tokens",
    "lint:rly-css-tokens": "tsx scripts/validateRlyCssTokens.ts",
    "preview": "vite preview --outDir dist/client --host 127.0.0.1 --port 4173 --strictPort",
    "start": "node ./dist/server/server/cli.js",
    "test": "vitest run",
    "test:browser": "pnpm test:e2e",
    "test:e2e": "pnpm --filter @knpkv/control-center^... build && pnpm build && playwright test --config playwright.config.ts",
    "validate:boundaries": "tsx scripts/validate-boundaries.ts",
    "validate:dist": "tsx scripts/validate-dist.ts"
  },
  "dependencies": {
    "@aws-sdk/credential-providers": "^3.1085.0",
    "@distilled.cloud/aws": "0.29.1",
    "@effect/platform-browser": "4.0.0-beta.98",
    "@effect/platform-node": "4.0.0-beta.98",
    "@effect/sql-libsql": "4.0.0-beta.98",
    "@knpkv/ai-claude": "workspace:^",
    "@knpkv/ai-codex": "workspace:^",
    "@knpkv/atlassian-common": "workspace:^",
    "@knpkv/codecommit-core": "workspace:^",
    "@knpkv/clockify-api-client": "workspace:^",
    "@knpkv/confluence-api-client": "workspace:^",
    "@knpkv/confluence-to-markdown": "workspace:^",
    "@knpkv/control-center-sql": "workspace:^",
    "@knpkv/jira-api-client": "workspace:^",
    "@knpkv/rly": "workspace:^",
    "effect": "4.0.0-beta.98",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.98",
    "@playwright/test": "1.61.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
