{
  "name": "@knpkv/control-center",
  "version": "0.0.0",
  "description": "Human- and agent-oriented delivery control center",
  "license": "MIT",
  "author": "knpkv",
  "repository": {
    "type": "git",
    "url": "https://github.com/knpkv/npm.git",
    "directory": "packages/control-center"
  },
  "type": "module",
  "main": "./dist/server/index.js",
  "types": "./dist/server/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./api": {
      "types": "./dist/server/api/index.d.ts",
      "import": "./dist/server/api/index.js"
    },
    "./domain": {
      "types": "./dist/server/domain/index.d.ts",
      "import": "./dist/server/domain/index.js"
    },
    "./server": {
      "types": "./dist/server/server/index.d.ts",
      "import": "./dist/server/server/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm validate:boundaries && rimraf dist && vite build --mode client && vite build --mode server && tsc -b tsconfig.server.json --force && pnpm validate:dist",
    "check": "pnpm validate:boundaries && tsc -b tsconfig.json",
    "clean": "rimraf dist *.tsbuildinfo node_modules/.cache",
    "dev": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "lint": "eslint \"{src,test,e2e,scripts}/**/*.{ts,tsx}\" vite.config.ts vitest.config.ts playwright.config.ts",
    "preview": "vite preview --outDir dist/client --host 127.0.0.1 --port 4173 --strictPort",
    "start": "pnpm preview",
    "test": "vitest run",
    "test:browser": "pnpm test:e2e",
    "test:e2e": "pnpm build && playwright test --config playwright.config.ts",
    "validate:boundaries": "tsx scripts/validate-boundaries.ts",
    "validate:dist": "tsx scripts/validate-dist.ts"
  },
  "dependencies": {
    "@knpkv/rly": "workspace:^",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@effect/platform-node": "4.0.0-beta.97",
    "@playwright/test": "1.61.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "effect": "4.0.0-beta.97",
    "rimraf": "^6.1.3",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
