{
  "name": "@knpkv/docs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "pnpm build:catalog && astro build && pnpm compose:catalog && pnpm validate:rly",
    "build:catalog": "pnpm --filter @knpkv/rly storybook:build",
    "compose:catalog": "node scripts/compose-rly-catalog.mjs",
    "preview": "astro preview",
    "check": "astro check && pnpm validate:rly:source",
    "validate:rly": "node scripts/validate-rly-docs.mjs",
    "validate:rly:source": "node scripts/validate-rly-docs.mjs --source-only",
    "clean": "rimraf dist .astro"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "7.2.1",
    "@astrojs/starlight": "^0.41.3",
    "astro": "^7.0.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "typescript": "~6.0.3"
  }
}
