{
  "name": "@knpkv/ai-runtime",
  "version": "0.0.0",
  "description": "Provider-neutral Effect runtime protocol for durable local AI agents",
  "license": "MIT",
  "author": "knpkv",
  "repository": {
    "type": "git",
    "url": "https://github.com/knpkv/npm.git",
    "directory": "packages/ai-runtime"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b --force",
    "check": "tsc --noEmit && tsc -p tsconfig.contract.json",
    "clean": "rimraf dist *.tsbuildinfo",
    "lint": "eslint \"{src,test,dtslint}/**/*.ts\"",
    "test": "vitest run"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.98"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.98",
    "effect": "4.0.0-beta.98",
    "rimraf": "^6.1.3",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "effect",
    "agent",
    "runtime",
    "codex",
    "claude"
  ]
}
