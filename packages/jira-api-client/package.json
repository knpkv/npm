{
  "name": "@knpkv/jira-api-client",
  "version": "0.2.0",
  "description": "Effect-based Jira Cloud REST API v3 client",
  "license": "MIT",
  "author": "knpkv",
  "repository": {
    "type": "git",
    "url": "https://github.com/knpkv/npm.git",
    "directory": "packages/jira-api-client"
  },
  "bugs": {
    "url": "https://github.com/knpkv/npm/issues"
  },
  "homepage": "https://github.com/knpkv/npm/tree/main/packages/jira-api-client#readme",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./src/index.ts"
    },
    "./JiraApiClient": {
      "import": "./dist/JiraApiClient.js",
      "types": "./src/JiraApiClient.ts"
    },
    "./JiraApiConfig": {
      "import": "./dist/JiraApiConfig.js",
      "types": "./src/JiraApiConfig.ts"
    },
    "./v3": {
      "import": "./dist/generated/v3/index.js",
      "types": "./src/generated/v3/index.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && cp src/generated/v3/schema.d.ts dist/generated/v3/schema.d.ts",
    "clean": "rimraf dist dist-test .tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "check": "tsc --noEmit",
    "regenerate": "tsx scripts/regenerate.ts",
    "regenerate:check": "tsx scripts/regenerate.ts --check"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.85"
  },
  "devDependencies": {
    "@effect/platform-node": "latest",
    "@effect/vitest": "4.0.0-beta.85",
    "@types/node": "latest",
    "effect": "latest",
    "openapi-typescript": "^7.13.0",
    "openapi-typescript-helpers": "^0.1.0",
    "tsx": "^4.19.4",
    "typescript": "~5.9.0",
    "vitest": "^4.0.13"
  },
  "keywords": [
    "effect",
    "effect-ts",
    "jira",
    "atlassian",
    "api-client",
    "openapi"
  ],
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  }
}
