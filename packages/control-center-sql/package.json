{
  "name": "@knpkv/control-center-sql",
  "version": "0.0.0",
  "description": "Typed SQL plans for Control Center persistence",
  "license": "MIT",
  "author": "knpkv",
  "repository": {
    "type": "git",
    "url": "https://github.com/knpkv/npm.git",
    "directory": "packages/control-center-sql"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b --force",
    "check": "tsc --noEmit",
    "clean": "rimraf dist *.tsbuildinfo",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "vitest run"
  },
  "dependencies": {
    "effect-qb": "0.20.0"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.98"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.98",
    "effect": "4.0.0-beta.98",
    "rimraf": "^6.1.3",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  }
}
