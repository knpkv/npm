{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.jsonc",
  "compilerOptions": {
    "emitDeclarationOnly": true,
    "jsx": "react-jsx",
    "outDir": "dist/dts",
    "rootDir": "src",
    "tsBuildInfoFile": "node_modules/.cache/tsconfig.build.tsbuildinfo",
    "types": ["vite/client"]
  },
  "include": ["src"],
  "exclude": [
    "dist",
    "node_modules",
    "test",
    "src/tokens/colors.ts",
    "src/tokens/model.ts",
    "src/tokens/motion.ts",
    "src/tokens/shape.ts",
    "src/tokens/space.ts",
    "src/tokens/typography.ts"
  ]
}
