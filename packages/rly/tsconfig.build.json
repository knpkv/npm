{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.jsonc",
  "compilerOptions": {
    "emitDeclarationOnly": true,
    "jsx": "react-jsx",
    "outDir": "dist/dts",
    "rootDir": "src",
    "tsBuildInfoFile": "node_modules/.cache/tsconfig.build.tsbuildinfo"
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules", "test"]
}
