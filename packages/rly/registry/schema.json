{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knpkv.dev/schemas/rly/components.schema.json",
  "additionalProperties": false,
  "properties": {
    "components": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "accessibility": {
            "additionalProperties": false,
            "properties": {
              "automatedChecks": {
                "const": true
              },
              "requirements": {
                "items": {
                  "minLength": 1,
                  "type": "string"
                },
                "minItems": 1,
                "type": "array",
                "uniqueItems": true
              },
              "standard": {
                "const": "WCAG 2.2 AA"
              }
            },
            "required": [
              "automatedChecks",
              "requirements",
              "standard"
            ],
            "type": "object"
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "category": {
            "enum": [
              "foundation",
              "primitive",
              "pattern",
              "diff"
            ],
            "type": "string"
          },
          "compatibleTokens": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "docs": {
            "additionalProperties": false,
            "properties": {
              "autogenerated": {
                "const": true
              },
              "storyId": {
                "minLength": 1,
                "pattern": "^[a-z0-9-]+--[a-z0-9-]+$",
                "type": "string"
              },
              "storyPath": {
                "minLength": 1,
                "pattern": "^\\?path=/story/[a-z0-9-]+--[a-z0-9-]+$",
                "type": "string"
              }
            },
            "required": [
              "autogenerated",
              "storyId",
              "storyPath"
            ],
            "type": "object"
          },
          "example": {
            "type": "string",
            "minLength": 1
          },
          "exports": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "kind": {
                  "enum": [
                    "type",
                    "value"
                  ],
                  "type": "string"
                },
                "name": {
                  "minLength": 1,
                  "type": "string"
                }
              },
              "required": [
                "kind",
                "name"
              ],
              "type": "object"
            },
            "minItems": 1,
            "type": "array"
          },
          "files": {
            "additionalProperties": false,
            "properties": {
              "source": {
                "minLength": 1,
                "pattern": "^src/",
                "type": "string"
              },
              "story": {
                "minLength": 1,
                "pattern": "^stories/",
                "type": "string"
              },
              "styles": {
                "items": {
                  "minLength": 1,
                  "pattern": "^src/",
                  "type": "string"
                },
                "type": "array",
                "uniqueItems": true
              },
              "tests": {
                "items": {
                  "minLength": 1,
                  "pattern": "^test/",
                  "type": "string"
                },
                "minItems": 1,
                "type": "array",
                "uniqueItems": true
              }
            },
            "required": [
              "source",
              "story",
              "styles",
              "tests"
            ],
            "type": "object"
          },
          "importPath": {
            "type": "string",
            "pattern": "^@knpkv/rly(?:/(?:tokens|foundations|primitives|patterns|diff(?:/workbench)?))?$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "props": {
            "additionalProperties": false,
            "properties": {
              "defaults": {
                "additionalProperties": {
                  "minLength": 1,
                  "type": "string"
                },
                "type": "object"
              },
              "types": {
                "items": {
                  "minLength": 1,
                  "type": "string"
                },
                "type": "array",
                "uniqueItems": true
              }
            },
            "required": [
              "defaults",
              "types"
            ],
            "type": "object"
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "slots": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "states": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "status": {
            "enum": [
              "experimental",
              "stable",
              "deprecated"
            ],
            "type": "string"
          },
          "variants": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "defaultValue": {
                  "minLength": 1,
                  "type": "string"
                },
                "description": {
                  "minLength": 1,
                  "type": "string"
                },
                "name": {
                  "minLength": 1,
                  "type": "string"
                },
                "values": {
                  "items": {
                    "additionalProperties": false,
                    "properties": {
                      "description": {
                        "minLength": 1,
                        "type": "string"
                      },
                      "name": {
                        "minLength": 1,
                        "type": "string"
                      }
                    },
                    "required": [
                      "description",
                      "name"
                    ],
                    "type": "object"
                  },
                  "minItems": 1,
                  "type": "array"
                }
              },
              "required": [
                "description",
                "name",
                "values"
              ],
              "type": "object"
            },
            "type": "array"
          }
        },
        "required": [
          "accessibility",
          "capabilities",
          "category",
          "compatibleTokens",
          "docs",
          "example",
          "exports",
          "files",
          "importPath",
          "name",
          "props",
          "purpose",
          "slots",
          "states",
          "status",
          "variants"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "generatedNotice": {
      "type": "string",
      "minLength": 1
    },
    "package": {
      "const": "@knpkv/rly"
    },
    "schemaVersion": {
      "const": 1
    }
  },
  "required": [
    "components",
    "generatedNotice",
    "package",
    "schemaVersion"
  ],
  "title": "@knpkv/rly component registry",
  "type": "object"
}
