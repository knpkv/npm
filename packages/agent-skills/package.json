{
  "name": "@knpkv/agent-skills",
  "version": "0.2.2",
  "description": "Installer for @knpkv agent skills",
  "license": "MIT",
  "author": "knpkv",
  "repository": {
    "type": "git",
    "url": "https://github.com/knpkv/npm.git",
    "directory": "packages/agent-skills"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "bin": {
    "knpkv-skills": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src",
    "skills"
  ],
  "scripts": {
    "start": "tsx src/bin.ts",
    "build": "tsc",
    "check": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.97",
    "effect": "4.0.0-beta.97"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "^4.23.0",
    "typescript": "~6.0.3"
  },
  "keywords": [
    "agent",
    "skills",
    "codex",
    "claude",
    "cli"
  ]
}
